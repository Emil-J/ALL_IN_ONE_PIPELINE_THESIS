flowchart TD

    %% ── Inputs ─────────────────────────────────────────────────
    subgraph IN["Inputs"]
        QGIS(["QGIS workflow<br/>(external · manual)<br/>see 11_dp_qgis_workflow"])
        BPTH_IN(["best.pth<br/>(from Semantic Training)"])
    end

